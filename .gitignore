# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
publish_env

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.pytype/

# ── IDEs and editors ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ── GStreamer / media leftovers ───────────────────────────────────────────────
# Test recordings or captures that might be created during development
*.mp4
*.mkv
*.webm
*.wav
*.ogg

# ── Secrets — never commit TLS certificates or keys ──────────────────────────
*.crt
*.key
*.pem
*.p12

# ── Tailscale certs (extra safety net) ───────────────────────────────────────
/var/
